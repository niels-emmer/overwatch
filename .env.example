# Copy to .env and adjust for your environment.
# docker compose automatically loads .env from the project root.

# URL of the Ollama instance.
# Can point to any host on the LAN — the VPS itself, your workstation, a dedicated AI box, etc.
# Default (host.docker.internal) works on Docker Desktop (Mac/Windows).
# On a Linux VPS use the host's LAN IP, e.g. http://192.168.1.x:11434, or add
#   extra_hosts: ["host.docker.internal:host-gateway"]
# to the backend service in docker-compose.yml instead.
OLLAMA_HOST=http://host.docker.internal:11434

# Port the web UI is exposed on.
OVERWATCH_PORT=8090
